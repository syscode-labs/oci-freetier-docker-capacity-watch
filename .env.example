OCI_PROFILE=default
WATCHER_IMAGE=ghcr.io/syscode-labs/oci-free-tier-docker-capacity-watch:latest
# Default to root for compatibility with strict host-mounted .oci permissions.
# Set to e.g. 1000:1000 if your mounted credentials are readable by that UID/GID.
CONTAINER_USER=0
# Directory containing OCI config + API key files.
OCI_MOUNT_DIR=/opt/oci-free-tier-worker/.oci
# SSH public key to inject in launched instances.
SSH_PUBLIC_KEY_FILE=/opt/oci-free-tier-worker/oci_free_tier.pub
# Shared profile defaults JSON controlling compute shape/count and free LB behavior.
PROFILE_DEFAULTS_FILE=/opt/oci-free-tier-worker/profile.defaults.json
COMPARTMENT_NAME=Default
RETRY_SECONDS=900
MAX_ATTEMPTS=0

# Notification backends: none|unraid|webhook
NOTIFY_BACKEND=none
NOTIFY_WEBHOOK_URL=

# On Unraid set this to: /usr/local/emhttp/webGui/scripts/notify
UNRAID_NOTIFY_BIN=/dev/null
